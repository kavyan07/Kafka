{
    "name": "reporting/kafka-pipeline",
    "description": "Kafka Producer & Consumer for Dynamic Reporting System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "monolog/monolog": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "produce": "php producer.php",
        "consume": "php consumer.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
